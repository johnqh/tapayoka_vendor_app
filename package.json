{
  "name": "tapayoka_vendor_app",
  "private": true,
  "version": "0.0.129",
  "type": "module",
  "scripts": {
    "process:static": "curl -sL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/process-static-files.ts -o /tmp/process-static-files.ts && bunx tsx /tmp/process-static-files.ts",
    "dev": "bun run process:static && vite",
    "seo:fetch": "curl -fsSL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/generate-seo-assets.mjs -o /tmp/generate-seo-assets.mjs",
    "build": "bun run process:static && bun run seo:fetch && node /tmp/generate-seo-assets.mjs public && tsc -b && vite build && node /tmp/generate-seo-assets.mjs dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "localize": "SCRIPT=$(mktemp) && curl -fsSL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/localize_batch.cjs -o $SCRIPT && node $SCRIPT ./public/locales https://api.whisperly.dev/api/v1/translate/jie9cytr/starter --word-limit 40 && rm -f $SCRIPT && prettier . --write",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\""
  },
  "dependencies": {
    "@sudobility/auth-components": "^1.0.11",
    "@sudobility/auth_lib": "^0.0.80",
    "@sudobility/building_blocks": "^0.0.262",
    "@sudobility/components": "^5.0.89",
    "@sudobility/design": "^1.1.40",
    "@sudobility/devops-components": "^2.0.19",
    "@sudobility/di": "^1.5.58",
    "@sudobility/di_web": "^0.1.203",
    "@sudobility/entity_client": "^0.0.36",
    "@sudobility/entity_pages": "^0.0.129",
    "@sudobility/seo_lib": "^0.0.32",
    "@sudobility/subscription_lib": "^0.0.44",
    "@sudobility/tapayoka_client": "^0.0.53",
    "@sudobility/tapayoka_lib": "^0.0.52",
    "@sudobility/tapayoka_types": "^0.0.47",
    "@sudobility/types": "^1.9.62",
    "@tanstack/react-query": "^5.90.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.0",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnqh/tapayoka_vendor_app.git"
  }
}
